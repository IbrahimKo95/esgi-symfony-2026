{% extends 'base.html.twig' %}

{% block title %}Modifier la transaction - ExpenseManager{% endblock %}

{% block main %}
    <div class="max-w-md mx-auto">
        <a href="{{ path('transaction_show', {id: transaction.id}) }}" class="text-sm text-indigo-600 hover:underline">&larr; Retour</a>
        <h1 class="text-xl font-bold text-gray-900 mt-1 mb-6">Modifier la transaction</h1>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
            {{ form_start(form) }}
                {{ form_row(form.amount) }}
                {{ form_row(form.date) }}
                {{ form_row(form.description) }}
                {{ form_row(form.wallet) }}
                {{ form_row(form.category) }}
                {{ form_row(form.tags) }}
                {% if form.source is defined %}
                    {{ form_row(form.source) }}
                {% endif %}
                {% if form.isRecurring is defined %}
                    {{ form_row(form.isRecurring) }}
                    {{ form_row(form.recurringTransaction) }}
                {% endif %}
                <button type="submit" class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-medium hover:bg-indigo-700 transition">Enregistrer</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
