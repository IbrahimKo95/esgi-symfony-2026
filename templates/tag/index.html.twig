{% extends 'base.html.twig' %}

{% block title %}Mes tags - ExpenseManager{% endblock %}

{% block main %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Mes tags</h1>
        <a href="{{ path('tag_new') }}" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">Nouveau tag</a>
    </div>

    {% if tags is empty %}
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-10 text-center text-gray-500">
            Vous n'avez pas encore de tag. Creez-en un pour organiser vos transactions.
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm divide-y divide-gray-100">
            {% for tag in tags %}
                <div class="flex justify-between items-center px-5 py-3">
                    <span class="inline-flex items-center gap-2 text-gray-800">
                        <span class="w-3 h-3 rounded-full" style="background-color: {{ tag.color|default('#6366f1') }}"></span>
                        {{ tag.name }}
                    </span>
                    <form method="post" action="{{ path('tag_delete', {id: tag.id}) }}" onsubmit="return confirm('Supprimer ce tag ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-tag-' ~ tag.id) }}">
                        <button type="submit" class="text-sm text-red-600 hover:underline">Supprimer</button>
                    </form>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
