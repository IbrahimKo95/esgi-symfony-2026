{% extends 'base.html.twig' %}

{% block title %}{{ client.firstName }} {{ client.lastName }} - ExpenseManager{% endblock %}

{% block main %}
    <a href="{{ path('advisor_index') }}" class="text-sm text-indigo-600 hover:underline">&larr; Mes clients</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-1 mb-6">{{ client.firstName }} {{ client.lastName }}</h1>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm mb-6">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-900">Anomalies</h2>
        </div>
        {% if anomalies is empty %}
            <p class="px-6 py-4 text-sm text-gray-500">Aucune anomalie.</p>
        {% else %}
            <table class="w-full text-sm">
                <thead class="text-left text-gray-500 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-2 font-normal">Severite</th>
                        <th class="px-6 py-2 font-normal">Message</th>
                        <th class="px-6 py-2 font-normal">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for anomaly in anomalies %}
                        <tr>
                            <td class="px-6 py-2">{{ anomaly.severity }}</td>
                            <td class="px-6 py-2">{{ anomaly.message }}</td>
                            <td class="px-6 py-2 text-gray-400">{{ anomaly.detectedAt|date('d/m/Y') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-900">Transactions recentes</h2>
        </div>
        {% if transactions is empty %}
            <p class="px-6 py-4 text-sm text-gray-500">Aucune transaction.</p>
        {% else %}
            <table class="w-full text-sm">
                <thead class="text-left text-gray-500 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-2 font-normal">Date</th>
                        <th class="px-6 py-2 font-normal">Description</th>
                        <th class="px-6 py-2 font-normal">Categorie</th>
                        <th class="px-6 py-2 font-normal text-right">Montant</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for transaction in transactions %}
                        <tr>
                            <td class="px-6 py-2 text-gray-400">{{ transaction.date|date('d/m/Y') }}</td>
                            <td class="px-6 py-2">{{ transaction.description|default('-') }}</td>
                            <td class="px-6 py-2">{{ transaction.category.name }}</td>
                            <td class="px-6 py-2 text-right">{{ transaction.amount }} {{ transaction.wallet.currency }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
