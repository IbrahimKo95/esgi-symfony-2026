{% extends 'base.html.twig' %}

{% block title %}Convertisseur de devises - ExpenseManager{% endblock %}

{% block main %}
    <div class="max-w-sm mx-auto">
        <h1 class="text-xl font-bold text-gray-900 mb-6">Convertisseur de devises</h1>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
            <form method="get" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Montant</label>
                    <input type="number" step="0.01" name="amount" value="{{ amount }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                </div>
                <div class="flex gap-3">
                    <div class="flex-1">
                        <label class="block text-sm font-medium text-gray-700 mb-1">De</label>
                        <select name="from" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                            {% for currency in currencies %}
                                <option value="{{ currency }}" {{ from == currency ? 'selected' }}>{{ currency }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="flex-1">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Vers</label>
                        <select name="to" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                            {% for currency in currencies %}
                                <option value="{{ currency }}" {{ to == currency ? 'selected' }}>{{ currency }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <button type="submit" class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-medium hover:bg-indigo-700 transition">Convertir</button>
            </form>

            {% if error %}
                <div class="mt-4 rounded-lg p-3 bg-red-50 text-red-700 text-sm border border-red-100">{{ error }}</div>
            {% elseif result is not null %}
                <div class="mt-4 rounded-lg p-3 bg-indigo-50 text-indigo-800 text-sm border border-indigo-100">
                    {{ amount }} {{ from }} = <strong>{{ result }} {{ to }}</strong>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
