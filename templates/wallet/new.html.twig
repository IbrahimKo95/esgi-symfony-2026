{% extends 'base.html.twig' %}

{% block title %}Nouveau portefeuille - ExpenseManager{% endblock %}

{% block main %}
    <div class="max-w-sm mx-auto">
        <h1 class="text-xl font-bold text-gray-900 mb-6">Nouveau portefeuille</h1>

        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
            {{ form_start(form) }}
                {{ form_row(form.name) }}
                {{ form_row(form.type) }}
                {{ form_row(form.currency) }}
                {{ form_row(form.isShared) }}
                <button type="submit" class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-medium hover:bg-indigo-700 transition">Creer</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
