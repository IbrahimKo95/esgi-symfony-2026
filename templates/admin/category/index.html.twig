{% extends 'base.html.twig' %}

{% block title %}Administration - Categories - ExpenseManager{% endblock %}

{% block main %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Categories globales</h1>
        <a href="{{ path('admin_category_new') }}" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">Nouvelle categorie</a>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm divide-y divide-gray-100">
        {% for category in categories %}
            <div class="px-6 py-3 flex justify-between items-center">
                <span class="inline-flex items-center gap-2 text-gray-800">
                    <span class="w-3 h-3 rounded-full" style="background-color: {{ category.color|default('#6366f1') }}"></span>
                    {{ category.name }}
                </span>
                <form method="post" action="{{ path('admin_category_delete', {id: category.id}) }}" onsubmit="return confirm('Supprimer cette categorie ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-category-' ~ category.id) }}">
                    <button type="submit" class="text-sm text-red-600 hover:underline">Supprimer</button>
                </form>
            </div>
        {% endfor %}
    </div>
{% endblock %}
